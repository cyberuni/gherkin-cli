{
	"name": "gherkin-cli",
	"version": "0.0.2",
	"description": "Agent-first Gherkin CLI — parse, validate, and diff .feature files with token-efficient, AXI-conformant output.",
	"keywords": [
		"gherkin",
		"cucumber",
		"feature",
		"cli",
		"agent",
		"axi",
		"toon"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/cyberuni/gherkin-cli.git"
	},
	"author": "unional <homawong@gmail.com>",
	"license": "MIT",
	"type": "module",
	"files": [
		"dist",
		"!dist/**/*.test.*"
	],
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"bin": {
		"gherkin-cli": "dist/cli.js"
	},
	"scripts": {
		"build": "tsdown",
		"dev": "tsx src/cli.ts",
		"format": "biome format --write .",
		"test": "vitest run src",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@cucumber/gherkin": "^41.0.0",
		"@cucumber/messages": "^33.0.0",
		"commander": "^14.0.0"
	},
	"devDependencies": {
		"@types/node": "^25.9.1",
		"tsdown": "^0.22.8",
		"tsx": "^4.23.1",
		"typescript": "^6.0.3",
		"vitest": "^4.1.10"
	},
	"engines": {
		"node": ">=22"
	}
}
