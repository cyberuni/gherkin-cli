{
	"name": "gherkin-cli-monorepo",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "turbo run build",
		"check": "biome check",
		"check:fix": "biome check --write",
		"gk": "pnpm run --filter=./packages/gherkin-cli",
