{
	"$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
	"extends": ["@repobuddy/biome/recommended"],
	"files": {
		"includes": ["!**/dist", "!**/node_modules", "!**/.turbo", "!**/.astro", "!.agents"]
	},
	"overrides": [
		{
			"includes": ["packages/gherkin-cli/src/**/*.ts"],
			"linter": {
				"rules": {
					"suspicious": {
						"noConsole": {
							"level": "error",
							"options": {
								"allow": ["log", "info", "warn", "error"]
							}
						}
					}
				}
			}
		}
	]
}
